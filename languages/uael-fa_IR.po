#. translators: %1$s doc link
#: modules/business-reviews/template-blocks/skin-style.php:352
msgid ""
"<span class=\"uael-reviews-notice-message elementor-clickable\"><span "
"class=\"uael-reviews-error-message\">Google Error Message: </"
"span>OVER_QUERY_LIMIT</br>You have exceeded your daily request quota for "
"this API. If you did not set a custom daily request quota, verify your "
"project has an active billing account. Visit your %1$s Google API console "
"%2$s to activate billing. </span>"
msgstr ""
"<span class=\"uael-reviews-notice-message elementor-clickable\"><span "
"class=\"uael-reviews-error-message\">پیام خطای گوگل: </"
"span>OVER_QUERY_LIMIT</br>شما سقف درخواست‌های روزانه‌تان برای این API را تجاوز "
"کرده‌اید. اگر سقف درخواست‌های روزانه خود را تنظیم نکرده‌اید، از وجود یک حساب "
"فعال با مالیات برخوردار در پروژه‌تان اطمینان حاصل کنید. برای فعال کردن "
"مالیات، به %1$s کنسول API گوگل %2$s بروید.</span>"

#: modules/business-reviews/template-blocks/skin-style.php:358
msgid ""
"<span class=\"uael-reviews-notice-message\"><span class=\"uael-reviews-error-"
"message\">Google Error Message: </span>REQUEST_DENIED</br>Invalid Google API "
"key! Please verify your API key from UAE settings.</span>"
msgstr ""
"<span class=\"uael-reviews-notice-message\"><span class=\"uael-reviews-error-"
"message\">پیام خطای گوگل: </span>REQUEST_DENIED</br>کلید Google API نامعتبر "
"است! لطفاً کلید API خود را از تنظیمات UAE (یو آی ای) خود تأیید کنید.</span>"

#: modules/business-reviews/template-blocks/skin-style.php:364
msgid ""
"<span class=\"uael-reviews-notice-message\"><span class=\"uael-reviews-error-"
"message\">Google Error Message: </span>UNKNOWN_ERROR </br>Seems like a "
"server-side error; Please try again later.</span>"
msgstr ""
"<span class=\"uael-reviews-notice-message\"><span class=\"uael-reviews-error-"
